# ============================================
# 全双工语音聊天机器人 - 环境变量配置
# ============================================
# 使用方式: cp .env.example .env  然后修改下方配置

# ============ DashScope API 配置 (核心 — 必需) ============
# 阿里云 DashScope API Key，LLM / TTS / ASR 三项共用
DASHSCOPE_API_KEY=sk-848d8e0d09c34d93b77961ad1ee009c1
# DashScope API 基地址 (OpenAI 兼容模式)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ASR 模型 (Fun-ASR 实时语音识别)
DASHSCOPE_ASR_MODEL=fun-asr-2025-11-07
# TTS 模型 (Qwen3-TTS 语音合成)
DASHSCOPE_TTS_MODEL=qwen3-tts-vd-2026-01-26

# ============ LiveKit 配置 (必需) ============
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ============ LLM 配置 ============
# 通过 DashScope OpenAI 兼容接口调用
LLM_MODEL=Qwen3.5-122B-W8A8

# ============ System Prompt 配置 ============
# 方式 A: 环境变量注入 (简单 demo/测试)
SYSTEM_PROMPT=你是一个友好、热情的语音助手，具有唱歌能力。当用户要求你唱歌时，调用 sing_a_song 工具，你需要根据用户的要求创作歌词。回复要简洁自然，适合语音对话。
# 方式 B: HTTP 动态拉取 (生产环境，留空则使用 SYSTEM_PROMPT)
PROMPT_SERVICE_URL=

# ============ VAD 配置 ============
VAD_THRESHOLD=0.5
VAD_MIN_SPEECH=0.2
VAD_MIN_SILENCE=0.3

# ============ 超时配置 (秒) ============
LLM_TIMEOUT=5
TTS_TIMEOUT=10
SINGING_TIMEOUT=30

# ============ RTC 端口范围 ============
RTC_PORT_START=50000
RTC_PORT_END=50050
